import lib/sugar
import lib/variables

// We define the boolean type.
|bool| -> [TF]
<(bool)> -> $1

// And its operations.
F and (bool) -> F
T and (@b: bool) -> @b
F or (@b: bool) -> @b
T or (bool) -> T
not T -> F
not F -> T

// And a conditional.
if T then (.*?) else (.*) -> $1
if F then (.*?) else (.*) -> $2


