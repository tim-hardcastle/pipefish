newtype 


Uid = clone int 

Apples = clone int using +, -
Oranges = clone int using +, -

Vec = clone list 



Color = enum RED, GREEN, BLUE, PURPLE

Dragon = struct(name string, age int?, color Color)



def 

(v Vec) + (w Vec) -> Vec :
    len(v) != len(w) :
        error "adding vectors of different lengths"
    else :
        Vec from r = [] for i::el = range v :
            r + [el + w[i]]
