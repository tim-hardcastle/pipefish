newtype

Person = struct(name string, age int) :
    name != ""
    age >= 0

EvenNumber = clone int :
    that mod 2 == 0

Thing = clone int :
    foo that 

var 

zero = 0
one = 1
x = 2
y = 3
neg = -99
goodNum = 42
badString = ""


def foo(i int) :
    i == 0 : 
        error "fnerg"
    i == 1 : 
        42
    i == 2 :
        false 
    else :
        true
