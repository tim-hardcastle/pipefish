newtype

Color = enum RED, ORANGE, YELLOW, GREEN, BLUE, PURPLE

Point = struct(xcoord, ycoord int)

var

myPoint = Point(1, 2)

myMap = map ("a"::RED, "b"::YELLOW, "c"::GREEN)

myList = [PURPLE, BLUE, GREEN, YELLOW, ORANGE, RED]

mySet = set "a", "e", "i", "o", "u"

myOtherSet = set(1, 2, 3)

mySnippet = -- foo |"bar"| spong

myTuple tuple = ("a", "b", "c", "d")

myOtherTuple tuple = (1, 2, 3)

var x = 0

cmd

init :
    global x
    for i = 0; i < 5; i + 1 :
        x = x + i

def

fib(n int) :
    first from a, b = 0, 1 for i = 0; i < n; i + 1 :
        b, a + b

collatzA(n) :
    from i = n for :
        i == 1 :
            break 
        i mod 2 == 0 :
            i div 2
        else :
            3 * i + 1

collatzB(n) :
    from i = n for i != 1 :
        i mod 2 == 0 :
            i div 2
        else :
            3 * i + 1

evens(x) :
    from L = [] for k::v = range x :
        k mod 2 == 0 :
            L + [v]
        else :
            continue

find(x, C) :
    from a = -1 for i::y = range C :
        x == y :
            break i 
        else :
            continue

findInTuple(x any?, C tuple) :
    from a = -1 for i::y = range C :
        x == y :
            break i 
        else :
            continue

add(x) :
    from a = 0 for _::v = range x :
        a + v

addTuple(x tuple) :
    from a = 0 for _::v = range x :
        a + v

countTuple(x tuple) :
    from a = 0 for i::_ = range x :
        a + 1

count(x) :
    from a = 0 for i::_ = range x :
        a + 1  

countTupleV(x tuple) :
    from a = 0 for _::v = range x :
        a + 1

countV(x) :
    from a = 0 for _::v = range x :
        a + 1  

countTupleKv(x tuple) :
    from a = 0 for k::v = range x :
        a + 1

countKv(x) :
    from a = 0 for k::v = range x :
        a + 1  


allKeys(x) :
    from L = [] for k:: _ = range x :
        L + [k]

allValues(x) :
    from L = [] for _::v = range x :
        L + [v]

showRange(x, y int) :
    from L = [] for k::v = range x::y :
        L + [k::v] 

showRangeKeys(x, y int) :
    from L = [] for k::_ = range x::y :
        L + [k] 

showRangeValues(x, y int) :
    from L = [] for _::v = range x::y :
        L + [v] 

triangle(n int) :
    from a = 0 for i::_ = range n + 1 :
        a + i

tridub(n int) :
    from a = 0 for i::_ = range n + 1 :
        a + j 
    given :
        j = 2 * i

