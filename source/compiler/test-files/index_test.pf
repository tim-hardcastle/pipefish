def

newtype

Color = enum RED, ORANGE, YELLOW, GREEN, BLUE, PURPLE

Shade = enum LIGHT, MEDIUM, DARK

Tone = struct(shade Shade, color Color)

Quark = struct(color Color, charm int)

Clist = clone list using slice

Cint = clone int 

const 

DARK_BLUE = Tone DARK, BLUE 

KEY = shade

var

myClist = Clist [RED, GREEN, BLUE] 

myCint = Cint 2

myColor = Tone LIGHT, GREEN 

mySubatomicParticle = Quark BLUE, 0

key = shade 

myType = Color

myMap = map ("a"::[1, 2], "b"::[3, 4], "c"::[5, 6])

myIndex = "a"

myList = [[1, 2], [3, 4], [5, 6]]

myPair = "foo"::"bar"

myIntPair = 0::2

myNumber = 2

myOtherNumber = 1

myWord = "Angela"

myTuple tuple = 1, 2, 3, 4

mySnippet = -- foo |"bar"| troz |"zort"|

myBool = true



def // Indexing when we don't know the types in advance is a different compilation from when we know one or both.

foo(x, y) :
    x[y]

goo(x tuple, y) :
    x[y]

ixs(S struct, k label) :
    S[k]

ixE(a, b bool) :
    (listOrError a)[numberOrError b]

listOrError(b bool) :
    b :
        error "this is my error"
    else :
        [0, 1, 2, 3]

numberOrError(b bool) :
    b :
        error "this is my error"
    else :
        2
    
