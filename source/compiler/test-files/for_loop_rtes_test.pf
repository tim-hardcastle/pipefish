def

foo(i int) :
    from a = "" for _::v = range 0::i :
        v == 3 :
            lowInt(i)
        else :    
            a & "zort"[v]

bar(i int) :
    from a string = fnerp(i) for _::v = range 0::i :
        a & "zort"[v]

fnerp(i int) :
    i == 5 :
        lowInt(i)
    else :
        ""

zort(i int) :
    from a = "" for j int = troz(i); j < i; j + 1 :
        a & "zort"[j]

rozt(i int) :
    from a = "" for j = troz(i); j < i; j + 1 :
        a & "zort"[j]

zrot(i int) :
    from a = "" for j = 0; j < i; j + xuq(i) :
        a & "zort"[j]

troz(i int) :
    i == 3 :
        lowString(i)
    else :
        0

qux(i int) :
    from a = "" for j = 0; j < i; xuq(i) :
        a & "zort"[j]

xuq(i int) :
    i == 3 :
        lowString(i)
    else :
        1

lowInt(i int) :
    i < 50 :
        42
    else :
        "foo"

lowString(i int) :
    i < 50 :
        "foo"
    else :
        42

count(A) :
    from a = 0 for _::i = range A :
        a + 1

merp(i int) :
    from a = 0 for j = 0; grerp(j); j + 1 :
        a + j 

grerp(i int) :
    i == 0 :
        true 
    else :
        86
